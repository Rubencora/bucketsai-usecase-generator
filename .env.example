OPENAI_API_KEY=your_openai_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here         # search API (fallback: DuckDuckGo)
FIRECRAWL_API_KEY=your_firecrawl_api_key_here   # web crawling for company data
PRESENTON_API_KEY=                               # optional: Presenton AI for decks
GAMMA_API_KEY=                                   # optional: Gamma.app Pro for premium decks
NEXT_PUBLIC_GAMMA_ENABLED=                       # set to 'true' if GAMMA_API_KEY is configured
DATABASE_URL=postgresql://user:pass@host:5432/db # PostgreSQL connection
JWT_SECRET=your_jwt_secret_here                  # auth token signing
